{
  "manifest_version": 3,
  "name": "Claude Usage Monitor",
  "version": "2.0.0",
  "description": "Display Claude usage information in the side panel",
  "permissions": [
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Claude Usage"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
